generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────────

enum StaffRole {
  ADMIN
  MANAGER
  STAFF
}

enum ServiceType {
  BEACH_BAR
  RESTAURANT
  APERITIVO
  VIP_CABANA
  VIP_BOTTLE
  TAKEAWAY
  EVENTS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_CANCELLATION
  REMINDER_24H
  REMINDER_1H
  EVENT_INQUIRY
  ORDER_READY
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ─── STAFF (dashboard users) ────────────────────────────────────────────────────

model Staff {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  hashedPassword String    @map("hashed_password")
  role           StaffRole @default(STAFF)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("staff")
}

// ─── CUSTOMERS (people who book) ────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings Booking[]

  @@index([email])
  @@map("customers")
}

// ─── MENU ITEMS (Beach Bar + Takeaway) ──────────────────────────────────────────

model MenuItem {
  id          String      @id @default(cuid())
  serviceType ServiceType @map("service_type")
  category    String
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?     @map("image_url")
  isAvailable Boolean     @default(true) @map("is_available")
  sortOrder   Int         @default(0) @map("sort_order")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@index([serviceType, category])
  @@map("menu_items")
}

// ─── ZONES (Restaurant + Aperitivo seating areas) ───────────────────────────────

model Zone {
  id          String      @id @default(cuid())
  serviceType ServiceType @map("service_type")
  name        String
  description String?
  supplement  Decimal     @default(0) @db.Decimal(10, 2)
  maxCapacity Int?        @map("max_capacity")
  isActive    Boolean     @default(true) @map("is_active")
  sortOrder   Int         @default(0) @map("sort_order")

  bookings Booking[]

  @@map("zones")
}

// ─── APERITIVO PACKAGES ─────────────────────────────────────────────────────────

model AperitivoPackage {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  includes    String[]
  isPopular   Boolean  @default(false) @map("is_popular")
  imageUrl    String?  @map("image_url")
  isAvailable Boolean  @default(true) @map("is_available")
  sortOrder   Int      @default(0) @map("sort_order")

  bookings Booking[]

  @@map("aperitivo_packages")
}

// ─── VIP PACKAGES (Cabanas + Bottle Service) ────────────────────────────────────

model VipPackage {
  id          String  @id @default(cuid())
  type        String // CABANA | BOTTLE
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  maxGuests   Int?    @map("max_guests")
  imageUrl    String? @map("image_url")
  isAvailable Boolean @default(true) @map("is_available")
  sortOrder   Int     @default(0) @map("sort_order")

  bookings Booking[]

  @@map("vip_packages")
}

// ─── BOOKINGS (unified for all 6 service types) ────────────────────────────────

model Booking {
  id          String        @id @default(cuid())
  serviceType ServiceType   @map("service_type")
  status      BookingStatus @default(PENDING)

  // Customer
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  // Timing
  date     DateTime @db.Date
  timeSlot String?  @map("time_slot")

  // Restaurant / Aperitivo
  guests Int?
  zoneId String? @map("zone_id")
  zone   Zone?   @relation(fields: [zoneId], references: [id])

  // Aperitivo specific
  aperitivoPackageId String?           @map("aperitivo_package_id")
  aperitivoPackage   AperitivoPackage? @relation(fields: [aperitivoPackageId], references: [id])

  // VIP specific
  vipPackageId String?     @map("vip_package_id")
  vipPackage   VipPackage? @relation(fields: [vipPackageId], references: [id])

  // Beach Bar specific
  locationCode String? @map("location_code")

  // Takeaway specific
  pickupTime  String? @map("pickup_time")
  orderNumber String? @unique @map("order_number")

  // Events specific
  eventType       String? @map("event_type")
  eventGuests     Int?    @map("event_guests")
  specialRequests String? @map("special_requests")

  // Financial
  totalAmount   Decimal? @db.Decimal(10, 2) @map("total_amount")
  depositAmount Decimal? @db.Decimal(10, 2) @map("deposit_amount")

  // Notes
  notes              String?
  cancellationReason String? @map("cancellation_reason")

  // Timestamps
  confirmedAt DateTime? @map("confirmed_at")
  cancelledAt DateTime? @map("cancelled_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  orderItems    OrderItem[]
  notifications NotificationLog[]

  @@index([serviceType, date])
  @@index([customerId])
  @@index([status])
  @@index([date])
  @@map("bookings")
}

// ─── ORDER ITEMS (line items for Beach Bar + Takeaway orders) ───────────────────

model OrderItem {
  id         String   @id @default(cuid())
  bookingId  String   @map("booking_id")
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  menuItemId String   @map("menu_item_id")
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2) @map("unit_price")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([bookingId])
  @@map("order_items")
}

// ─── BUSINESS SETTINGS (single row, singleton config) ───────────────────────────

model BusinessSettings {
  id                String   @id @default("default")
  name              String   @default("Riva Beach Salento")
  description       String?
  logoUrl           String?  @map("logo_url")
  email             String?
  phone             String?
  address           String?
  timezone          String   @default("Europe/Rome")
  currency          String   @default("EUR")
  openingTime       String   @default("10:00") @map("opening_time")
  closingTime       String   @default("23:00") @map("closing_time")
  maxGuestsPerSlot  Int      @default(50) @map("max_guests_per_slot")
  cancellationHours Int      @default(48) @map("cancellation_hours")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("business_settings")
}

// ─── NOTIFICATION LOG ───────────────────────────────────────────────────────────

model NotificationLog {
  id        String             @id @default(cuid())
  bookingId String?            @map("booking_id")
  booking   Booking?           @relation(fields: [bookingId], references: [id])
  channel   NotificationChannel
  type      NotificationType
  recipient String
  subject   String?
  body      String?
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?          @map("sent_at")
  error     String?
  createdAt DateTime           @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([status])
  @@map("notification_logs")
}
